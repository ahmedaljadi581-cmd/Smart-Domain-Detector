# Optional: force using Vite middleware in development.
# USE_VITE_DEV=true

# Optional: server port (defaults to 3000 if not provided)
# PORT=3000

# Optional: ProjectDiscovery Chaos API key for the chaos source
# PDCP_API_KEY=

# Optional: BufferOver API key for passive DNS enrichment
# BUFFEROVER_API_KEY=
